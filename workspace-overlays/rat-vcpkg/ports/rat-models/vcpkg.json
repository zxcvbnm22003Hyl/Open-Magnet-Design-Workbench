{
  "name": "rat-models",
  "version-string": "2.020.1",
  "port-version": 1,
  "description": "Rat-Models C++ Library",
  "homepage": "https://gitlab.com/Project-Rat/rat-models",
  "license": "MIT",
  "dependencies": [
    "distmesh-cpp",
    "materials-cpp",
    "nlopt",
    "rat-common",
    "rat-math",
    "rat-mlfmm",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "vcpkg-tool-ninja",
      "host": true
    },
    {
      "name": "vtk"
    }
  ],
  "default-features": [
    "nl"
  ],
  "features": {
    "nl": {
      "description": "Enable Non-Linear solver (requires rat-nl)",
      "dependencies": [
        "rat-nl"
      ]
    }
  }
}
